---
import ThemeToggle from "./ThemeToggle.astro";

const navLinks = [
  { href: "/", label: "홈" },
  { href: "/blog", label: "블로그" },
  { href: "/about", label: "소개" },
];

const pathname = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 border-b border-border-light bg-surface-light/80 backdrop-blur-md dark:border-border-dark dark:bg-surface-dark/80"
>
  <nav class="mx-auto flex max-w-4xl items-center justify-between px-4 py-3">
    <a href="/" class="text-lg font-bold tracking-tight">
      ai.dev.blog
    </a>

    <!-- Desktop nav -->
    <div class="hidden items-center gap-6 md:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-sm transition-colors hover:text-primary-600 dark:hover:text-primary-400",
              pathname === link.href || (link.href !== "/" && pathname.startsWith(link.href))
                ? "font-medium text-primary-600 dark:text-primary-400"
                : "text-muted-light dark:text-muted-dark",
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <ThemeToggle />
    </div>

    <!-- Mobile menu button -->
    <div class="flex items-center gap-2 md:hidden">
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="메뉴 열기"
        class="rounded-lg p-2 text-muted-light hover:bg-gray-100 dark:text-muted-dark dark:hover:bg-gray-800"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden border-t border-border-light px-4 pb-4 dark:border-border-dark md:hidden">
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "block py-2 text-sm transition-colors hover:text-primary-600 dark:hover:text-primary-400",
            pathname === link.href || (link.href !== "/" && pathname.startsWith(link.href))
              ? "font-medium text-primary-600 dark:text-primary-400"
              : "text-muted-light dark:text-muted-dark",
          ]}
        >
          {link.label}
        </a>
      ))
    }
  </div>
</header>

<script>
  document.getElementById("mobile-menu-btn")!.addEventListener("click", () => {
    document.getElementById("mobile-menu")!.classList.toggle("hidden");
  });
</script>
