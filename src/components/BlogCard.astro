---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../utils/formatDate";
import { getReadingTime } from "../utils/readingTime";
import { getSlug } from "../utils/getSlug";
import TagPill from "./TagPill.astro";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, pubDate, category, tags, heroImage } = post.data;
const readingTime = getReadingTime(post.body ?? "");
---

<article class="group border-b border-border-light py-6 last:border-b-0 dark:border-border-dark">
  <a href={`/blog/${getSlug(post.id)}`} class="flex flex-col gap-4 sm:flex-row">
    {heroImage && (
      <div class="shrink-0 overflow-hidden rounded-lg sm:w-48">
        <img
          src={heroImage}
          alt={title}
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
      </div>
    )}

    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-2 text-sm text-muted-light dark:text-muted-dark">
        <span>{category}</span>
        <span>&middot;</span>
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        <span>&middot;</span>
        <span>{readingTime}</span>
      </div>

      <h2 class="mt-2 text-xl font-semibold transition-colors group-hover:text-primary-600 dark:group-hover:text-primary-400">
        {title}
      </h2>

      <p class="mt-2 text-muted-light line-clamp-2 dark:text-muted-dark">
        {description}
      </p>

      {
        tags.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-1.5">
            {tags.map((tag) => (
              <TagPill tag={tag} />
            ))}
          </div>
        )
      }

      <span
        class="mt-3 inline-flex items-center text-sm font-medium text-primary-600 transition-colors group-hover:text-primary-500 dark:text-primary-400 dark:group-hover:text-primary-300"
      >
        더 읽기
        <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </span>
    </div>
  </a>
</article>
