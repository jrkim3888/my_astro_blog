---
import BaseLayout from "./BaseLayout.astro";
import TagPill from "../components/TagPill.astro";
import Giscus from "../components/Giscus.astro";
import { formatDate } from "../utils/formatDate";
import { getReadingTime } from "../utils/readingTime";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  tags: string[];
  body: string;
}

const { title, description, pubDate, updatedDate, category, tags, body } =
  Astro.props;
const readingTime = getReadingTime(body);
---

<BaseLayout title={`${title} | ai.dev.blog`} description={description}>
  <article class="mx-auto max-w-4xl px-4 py-10">
    <!-- Back link -->
    <a
      href="/blog"
      class="inline-flex items-center text-sm text-muted-light transition-colors hover:text-primary-600 dark:text-muted-dark dark:hover:text-primary-400"
    >
      <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
      </svg>
      블로그로 돌아가기
    </a>

    <!-- Post header -->
    <header class="mt-6">
      <div class="flex items-center gap-2 text-sm text-muted-light dark:text-muted-dark">
        <span>{category}</span>
        <span>&middot;</span>
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        <span>&middot;</span>
        <span>{readingTime}</span>
      </div>

      <h1 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">
        {title}
      </h1>

      <p class="mt-3 text-lg text-muted-light dark:text-muted-dark">
        {description}
      </p>

      {
        tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-1.5">
            {tags.map((tag) => (
              <TagPill tag={tag} />
            ))}
          </div>
        )
      }

      {
        updatedDate && (
          <p class="mt-3 text-sm italic text-muted-light dark:text-muted-dark">
            마지막 수정: {formatDate(updatedDate)}
          </p>
        )
      }
    </header>

    <!-- Post content -->
    <div class="prose mt-10">
      <slot />
    </div>
  </article>

  <!-- Comments -->
  <Giscus />
</BaseLayout>
